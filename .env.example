# ── Deepgram ────────────────────────────────────────────────────────────────
# Get from: https://console.deepgram.com
DEEPGRAM_API_KEY=

# Comma-separated corporate keywords for vocabulary tuning (Phase 4)
# e.g. "Nikhelesh,WorkBoard,JIRA-1234"
DEEPGRAM_KEYWORDS=

# ── DeepSeek ─────────────────────────────────────────────────────────────────
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ── Microsoft Azure AD (for Graph API) ───────────────────────────────────────
# Register an app at https://portal.azure.com → App registrations
# Required permissions: Calendars.ReadWrite, Mail.ReadWrite, Mail.Send
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Email address of the executive whose calendar is managed
EXEC_EMAIL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Production: your Upstash / Redis Cloud URL
REDIS_URL=redis://localhost:6379

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
# Run supabase/schema.sql against your project first
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Slack Notifications ────────────────────────────────────────────────────────
# Create an incoming webhook in your Slack workspace:
# Slack API → Your Apps → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# ── Jira Integration ──────────────────────────────────────────────────────────
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_PROJECT_KEY=ENG
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=
